---
import ContentCard from './ContentCard.astro';
import type { ContentItem } from '../data/content';

interface Props {
  items: ContentItem[];
  featured?: boolean;
  emptyMessage?: string;
}
const { items, featured = false, emptyMessage = 'Nothing here yet. Check back soon.' } = Astro.props;
---

{
  items.length > 0 ? (
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 [grid-auto-rows:1fr]">
      {items.map((item) => (
        <ContentCard item={item} featured={featured} />
      ))}
    </div>
  ) : (
    <p class="rounded-[var(--radius-card)] border border-dashed px-5 py-10 text-center text-sm" style="color: var(--fg-subtle); border-color: var(--border)">
      {emptyMessage}
    </p>
  )
}
