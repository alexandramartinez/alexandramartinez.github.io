---
interface Props {
  title?: string;
  eyebrow?: string;
  id?: string;
  href?: string; // optional "view all" link
  hrefLabel?: string;
}
const { title, eyebrow, id, href, hrefLabel = 'View all' } = Astro.props;
---

<section id={id} class="mx-auto max-w-6xl px-5 py-12 sm:py-16">
  {
    (title || eyebrow) && (
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          {eyebrow && (
            <p class="mb-2 flex items-center gap-2 font-mono text-xs uppercase tracking-[0.2em]" style="color: var(--color-accent)">
              <span class="gradient-bar" aria-hidden="true" />
              {eyebrow}
            </p>
          )}
          {title && (
            <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
          )}
        </div>
        {href && (
          <a
            href={href}
            class="shrink-0 font-mono text-sm transition-colors hover:text-[var(--color-accent)]"
            style="color: var(--fg-muted)"
          >
            {hrefLabel} →
          </a>
        )}
      </div>
    )
  }
  <slot />
</section>
