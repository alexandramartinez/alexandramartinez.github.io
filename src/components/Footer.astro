---
import { site, startup } from '../config';
import Socials from './Socials.astro';
import Wordmark from './Wordmark.astro';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t" style="border-color: var(--border)">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-col gap-2">
      <Wordmark />
      <p class="text-sm" style="color: var(--fg-subtle)">
        {site.tagline}
      </p>
      <p class="text-xs" style="color: var(--fg-subtle)">
        Currently {startup.role} at{' '}
        <a
          href={startup.href}
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-2 hover:underline"
          style="color: var(--color-accent)">{startup.name}</a
        >.
      </p>
    </div>
    <div class="flex flex-col gap-3 sm:items-end">
      <Socials />
      <p class="font-mono text-xs" style="color: var(--fg-subtle)">
        © {year} {site.name}
      </p>
    </div>
  </div>
</footer>
