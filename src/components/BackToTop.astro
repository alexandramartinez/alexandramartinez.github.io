---
/** Floating "back to top" button. Inline script keeps it dependency-free and instant. */
---

<button
  id="back-to-top"
  type="button"
  class="fixed bottom-6 right-6 z-50 inline-flex h-11 w-11 translate-y-2 items-center justify-center rounded-full opacity-0 shadow-lg transition-all duration-200 invisible"
  style="background: var(--color-accent); color: var(--color-accent-ink)"
  aria-label="Back to top"
>
  <svg
    class="h-5 w-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 19V5M5 12l7-7 7 7"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;
    function sync() {
      const show = window.scrollY > 400;
      btn.classList.toggle('opacity-0', !show);
      btn.classList.toggle('invisible', !show);
      btn.classList.toggle('translate-y-2', !show);
    }
    sync();
    window.addEventListener('scroll', sync, { passive: true });
    btn.addEventListener('click', () => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
    });
  })();
</script>
