---
import Tag from './Tag.astro';
import type { ContentItem } from '../data/content';
import { presentContentItem } from '../lib/present';

interface Props {
  item: ContentItem;
  featured?: boolean;
}
const { item, featured = false } = Astro.props;

// Derived display values (label, cover, playable, formatted date). The badges
// below (duration, language, stars, forks) stay inline: they are conditional
// markup over item.meta, not derivation.
const { label, dateLabel, cover, playable } = presentContentItem(item);
---

<a
  href={item.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col overflow-hidden rounded-[var(--radius-card)] border transition-all duration-300 hover:-translate-y-1"
  style="background: var(--bg-card); border-color: var(--border)"
>
  {
    cover && (
      <div class="relative aspect-video w-full overflow-hidden" style="background: var(--bg-elevated)">
        <img
          src={cover}
          alt=""
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        {playable && (
          <span class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-black/50 transition-transform duration-300 group-hover:scale-110">
              <svg viewBox="0 0 24 24" fill="white" class="ml-0.5 h-6 w-6">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
          </span>
        )}
        {item.meta?.duration && (
          // Runtime badge: white on a dark scrim for contrast over any thumbnail.
          <span class="absolute bottom-2 right-2 rounded bg-black/70 px-1.5 py-0.5 font-mono text-xs font-medium text-white">
            {item.meta.duration}
          </span>
        )}
      </div>
    )
  }
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex flex-wrap items-center gap-2">
      <Tag label={label} type={item.type} />
      <span class="font-mono text-xs" style="color: var(--fg-subtle)">{item.source}</span>
    </div>
    <h3
      class={`font-semibold leading-snug transition-colors group-hover:text-[var(--color-accent)] ${featured ? 'text-xl' : 'text-base'}`}
    >
      {item.title}
    </h3>
    {
      item.description && (
        <p class={`text-sm ${featured ? 'line-clamp-3' : 'line-clamp-2'}`} style="color: var(--fg-muted)">
          {item.description}
        </p>
      )
    }
    <div
      class="mt-auto flex items-center gap-3 pt-1 font-mono text-xs"
      style="color: var(--fg-subtle)"
    >
      {dateLabel && <span>{dateLabel}</span>}
      {
        item.meta?.language && (
          <span class="inline-flex items-center gap-1">
            <span
              class="inline-block h-2 w-2 rounded-full"
              style="background: var(--color-accent-2)"
            />
            {item.meta.language}
          </span>
        )
      }
      {item.meta?.stars !== undefined && Number(item.meta.stars) > 0 && (
        <span class="inline-flex items-center gap-1">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="h-3.5 w-3.5">
            <path d="M8 .25l2.06 4.17 4.61.67-3.33 3.25.78 4.59L8 10.77l-4.12 2.16.78-4.59L1.33 5.09l4.61-.67L8 .25z" />
          </svg>
          {item.meta.stars}
        </span>
      )}
      {item.meta?.forks !== undefined && Number(item.meta.forks) > 0 && (
        <span class="inline-flex items-center gap-1">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="h-3.5 w-3.5">
            <path d="M5 3.25a1.75 1.75 0 10-2.5 1.58v2.84A2.75 2.75 0 005.25 10.5h1.5v1.92a1.75 1.75 0 101.5 0V10.5h1.5a2.75 2.75 0 002.75-2.83V4.83A1.75 1.75 0 1010 3.25a1.75 1.75 0 001 1.58v2.84c0 .69-.56 1.25-1.25 1.25h-4.5c-.69 0-1.25-.56-1.25-1.25V4.83A1.75 1.75 0 005 3.25z" />
          </svg>
          {item.meta.forks}
        </span>
      )}
    </div>
  </div>
</a>
