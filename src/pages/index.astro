---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import FeedGrid from '../components/FeedGrid.astro';
import Button from '../components/Button.astro';
import Tag from '../components/Tag.astro';
import { getAllContent } from '../data/content';
import type { ContentItem } from '../data/content';

// Static content catalog (manually maintained in src/data/content.ts).
const latest = getAllContent().slice(0, 6);

// Curated featured set.
const featuredEntries = (await getCollection('featured')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
const featuredItems: ContentItem[] = featuredEntries.map((e) => ({
  type: e.data.type,
  title: e.data.title,
  url: e.data.url,
  date: e.data.date ? e.data.date.toISOString() : '',
  source: e.data.source ?? '',
  description: e.data.blurb,
  thumbnail: e.data.thumbnail,
  meta: {
    ...(e.data.duration ? { duration: e.data.duration } : {}),
    ...(e.data.stars !== undefined ? { stars: e.data.stars } : {}),
    ...(e.data.forks !== undefined ? { forks: e.data.forks } : {}),
  },
}));
---

<Base>
  <!-- HERO -->
  <section class="hero-glow relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-5 pb-12 pt-20 sm:pt-28">
      <div class="flex flex-col-reverse gap-10 lg:flex-row lg:items-center lg:gap-14">
        <div class="flex-1">
          <p class="mb-4 font-mono text-sm tracking-wide" style="color: var(--color-accent)">
            Hi, I'm Alex.
          </p>
          <h1
            class="font-bold tracking-tight"
            style="font-size: var(--text-hero); line-height: var(--text-hero--line-height)"
          >
            I build, teach,<br />
            and create for<br />
            <span class="text-gradient">developers.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg" style="color: var(--fg-muted)">
            Software engineer turned developer advocate. Five years creating content on MuleSoft,
            AI, DataWeave, and building with Claude. Videos, articles, livestreams, and open source.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <Button href="/portfolio">See my portfolio</Button>
          </div>
          <div class="mt-6 flex flex-wrap gap-2">
            <Tag label="MuleSoft" />
            <Tag label="AI" />
            <Tag label="DataWeave" />
            <Tag label="Vibe coding" />
            <Tag label="Claude" />
          </div>
        </div>
        <div class="w-full max-w-xs shrink-0 lg:max-w-sm">
          <div class="gradient-frame overflow-hidden rounded-[var(--radius-card)]">
          <img
            src="/alex.png"
            alt="Alex Martinez"
            width="800"
            height="800"
            decoding="async"
            class="aspect-square h-full w-full object-cover"
          />
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="gradient-divider mx-auto max-w-6xl" />

  <!-- FEATURED -->
  {
    featuredItems.length > 0 && (
      <Section eyebrow="Featured" title="Best work">
        <FeedGrid items={featuredItems} featured />
      </Section>
    )
  }

  <!-- LATEST (live feeds) -->
  <Section eyebrow="Recent" title="Latest" href="/portfolio" hrefLabel="All content">
    <FeedGrid
      items={latest}
      emptyMessage="Latest videos, repos, and articles will appear here."
    />
  </Section>

  <!-- BOOKKEEPING CALLOUT -->
  <Section>
    <div
      class="gradient-frame flex flex-col items-start gap-5 rounded-[var(--radius-card)] p-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="mb-1 font-mono text-xs uppercase tracking-[0.2em]" style="color: var(--color-accent-2)">
          Also offering
        </p>
        <h2 class="text-2xl font-bold tracking-tight">Bookkeeping services</h2>
        <p class="mt-2 max-w-xl text-sm" style="color: var(--fg-muted)">
          QuickBooks Online certified, taking on new clients. Clean books, clear reporting,
          done right.
        </p>
      </div>
      <Button href="/bookkeeping" variant="secondary">Learn more</Button>
    </div>
  </Section>
</Base>
